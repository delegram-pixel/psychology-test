generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                      String              @id @default(cuid())
  name                    String?
  email                   String?             @unique
  emailVerified           DateTime?
  image                   String?
  passwordHash            String?
  verificationToken       String?             @unique
  verificationTokenExpiry DateTime?
  accounts                Account[]
  assessmentSessions      AssessmentSession[]
  patients                Patient[]
  scales                  Scale[]
  sessions                Session[]
}

model Scale {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  psychologistId     String?
  isLibrary          Boolean             @default(false)
  createdAt          DateTime            @default(now())
  assessmentSessions AssessmentSession[]
  psychologist       User?               @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  items              ScaleItem[]
  thresholds         SeverityThreshold[]
}

model ScaleItem {
  id       String           @id @default(cuid())
  scaleId  String
  order    Int
  text     String
  type     ItemType
  required Boolean          @default(true)
  options  ResponseOption[]
  scale    Scale            @relation(fields: [scaleId], references: [id], onDelete: Cascade)
}

model ResponseOption {
  id     String    @id @default(cuid())
  itemId String
  label  String
  value  Int?
  order  Int
  item   ScaleItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model SeverityThreshold {
  id       String @id @default(cuid())
  scaleId  String
  label    String
  minScore Int
  maxScore Int
  scale    Scale  @relation(fields: [scaleId], references: [id], onDelete: Cascade)
}

model Patient {
  id                 String              @id @default(cuid())
  displayName        String
  anonymousId        String
  psychologistId     String
  createdAt          DateTime            @default(now())
  assessmentSessions AssessmentSession[]
  psychologist       User                @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@unique([anonymousId, psychologistId])
}

model AssessmentSession {
  id             String                 @id @default(cuid())
  patientId      String
  psychologistId String
  scaleId        String
  status         SessionStatus          @default(PENDING)
  token          String                 @unique
  tokenExpiresAt DateTime
  createdAt      DateTime               @default(now())
  patient        Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologist   User                   @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  scale          Scale                  @relation(fields: [scaleId], references: [id])
  response       QuestionnaireResponse?
}

model QuestionnaireResponse {
  id          String            @id @default(cuid())
  sessionId   String            @unique
  itemScores  Json
  totalScore  Int
  severity    String
  completedAt DateTime          @default(now())
  session     AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum ItemType {
  MULTIPLE_CHOICE
  YES_NO
  FREE_TEXT
  NUMBER
}

enum SessionStatus {
  PENDING
  COMPLETED
  EXPIRED
}
